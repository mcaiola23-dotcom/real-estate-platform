{
  "name": "@real-estate/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test:smoke": "node --import tsx --test tests/smoke/tenant-runtime.smoke.test.ts tests/smoke/public-api.smoke.test.ts tests/smoke/listings-provider.smoke.test.ts tests/smoke/seo-aeo.smoke.test.ts",
    "test:perf": "node --import tsx --test tests/perf/home-search.perf.test.ts",
    "check": "npm run lint && npm run typecheck && npm run test:smoke && npm run test:perf",
    "verify:seo-aeo": "node --import tsx scripts/verify-seo-aeo.ts",
    "verify:idx-provider": "node --import tsx scripts/verify-idx-provider.ts",
    "verify:launch": "npm run verify:seo-aeo && npm run verify:idx-provider",
    "sanity:tenant-backfill": "node --import tsx scripts/backfill-sanity-tenant-content.ts",
    "tenant:onboard:scaffold": "node --import tsx scripts/scaffold-tenant-onboarding.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.37.3",
    "@portabletext/react": "^6.0.2",
    "@real-estate/db": "*",
    "@real-estate/types": "*",
    "@sanity/client": "^7.14.0",
    "@sanity/image-url": "^2.0.2",
    "leaflet": "^1.9.4",
    "lightningcss-win32-x64-msvc": "^1.30.2",
    "next": "16.1.1",
    "next-sanity": "^12.0.8",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
