# ==============================================================================
# SmartMLS AI Platform - Frontend Environment Variables
# ==============================================================================
# Copy this file to .env.local and fill in the values for your environment.

# ------------------------------------------------------------------------------
# Environment
# ------------------------------------------------------------------------------
# Options: local, staging, production
NEXT_PUBLIC_ENVIRONMENT=local

# ------------------------------------------------------------------------------
# Backend API
# ------------------------------------------------------------------------------
# Canonical backend base URL. Client components call through `/api/portal`,
# and server-side fetches/proxy routes resolve upstream from this variable.
# Local: http://localhost:8000
# Staging: https://smartmls-backend-staging.onrender.com
# Production: https://smartmls-backend.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# ------------------------------------------------------------------------------
# Google Maps Browser Key (Optional)
# ------------------------------------------------------------------------------
# Only needed if the frontend calls Google APIs directly from the browser.
# Current portal flow proxies Places/StreetView/Commute through portal-api,
# so this should usually remain unset.
# If used, restrict by HTTP referrer and allowed APIs.
# NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_API_KEY=

# ------------------------------------------------------------------------------
# Mapbox (Map Tiles)
# ------------------------------------------------------------------------------
# Get your token from https://account.mapbox.com/access-tokens/
# The default token is for development only
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_public_token_here

# ------------------------------------------------------------------------------
# Sentry (Error Tracking)
# ------------------------------------------------------------------------------
# Get these from https://sentry.io - create a Next.js project
NEXT_PUBLIC_SENTRY_DSN=

# For source map uploads during build (not required for error tracking)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ------------------------------------------------------------------------------
# PostHog (Product Analytics)
# ------------------------------------------------------------------------------
# Get your key from https://posthog.com
# Create a project and find the key in Project Settings
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ------------------------------------------------------------------------------
# Feature Flags (Optional)
# ------------------------------------------------------------------------------
# NEXT_PUBLIC_ENABLE_AI_SEARCH=true
# NEXT_PUBLIC_ENABLE_STREET_VIEW=true

# ------------------------------------------------------------------------------
# NextAuth.js (Authentication)
# ------------------------------------------------------------------------------
# Required: Generate with `openssl rand -base64 32`
NEXTAUTH_SECRET=

# Required: Your application URL (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# Google OAuth - https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth (optional) - https://developers.facebook.com/apps/
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Apple OAuth (optional) - https://developer.apple.com/
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
